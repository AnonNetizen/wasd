# EditorConfig — 统一编辑器行为，与 .gitattributes 互补
# 详见 https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# Godot 推荐 tab 缩进
[*.{gd,gdshader,tscn,tres}]
indent_style = tab
indent_size = 4

# 数据文件用空格缩进，便于人和 AI 阅读
[*.{json,yml,yaml,toml,csv}]
indent_style = space
indent_size = 2

# Markdown 保留行尾空格（用于换行），不强制裁剪
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Windows 批处理需要 CRLF
[*.{bat,cmd}]
end_of_line = crlf
