; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="wasd"
run/main_scene="res://scenes/boot/main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

DataLoader="*res://scripts/autoload/data_loader.gd"
RNG="*res://scripts/autoload/rng.gd"
GameState="*res://scripts/autoload/game_state.gd"
GameClock="*res://scripts/autoload/game_clock.gd"
Settings="*res://scripts/autoload/settings.gd"
Analytics="*res://scripts/autoload/analytics.gd"
Replay="*res://scripts/autoload/replay.gd"
PoolManager="*res://scripts/autoload/pool_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
Localization="*res://scripts/autoload/localization.gd"
UIManager="*res://scripts/autoload/ui_manager.gd"
Combat="*res://scripts/combat/combat.gd"
